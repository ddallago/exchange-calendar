# Copia questo file in ".env" e compila i valori con i tuoi dati.
# Il file .env NON va mai caricato su GitHub (e' gia' escluso da .gitignore).

# Endpoint EWS del tuo Exchange
EXCHANGE_EWS_URL=https://mail.esempio.com/EWS/Exchange.asmx

# Login NTLM: DOMINIO\utente  (oppure prova con l'indirizzo email completo)
EXCHANGE_USERNAME=DOMINIO\utente

# Password della casella
EXCHANGE_PASSWORD=la_tua_password

# Indirizzo email principale della casella da leggere
EXCHANGE_EMAIL=nome.cognome@esempio.com

# Fuso orario (opzionale)
EXCHANGE_TIMEZONE=Europe/Rome

# Verifica certificato TLS: true = sicuro (consigliato).
# Metti false SOLO se il server usa un certificato self-signed interno.
EXCHANGE_VERIFY_SSL=true
