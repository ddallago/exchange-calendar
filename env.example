# INSTRUCTIONS:
# 1) Copy/rename this file adding a DOT in front of the name: from "env.example" to ".env"
#    (the leading dot makes it the hidden config file the script actually reads).
# 2) Fill in the values below with your own data.
# The .env file must NEVER be committed to GitHub (it is already excluded by .gitignore).

# EWS endpoint of your Exchange server (must be https://)
EXCHANGE_EWS_URL=https://mail.example.com/EWS/Exchange.asmx

# NTLM login: DOMAIN\user  (or try your full email address)
EXCHANGE_USERNAME=DOMAIN\user

# Mailbox password
EXCHANGE_PASSWORD=your_password

# Primary email address of the mailbox to read
EXCHANGE_EMAIL=name.surname@example.com

# Timezone (optional)
EXCHANGE_TIMEZONE=Europe/Rome

# TLS certificate verification: true = secure (recommended).
# Set false ONLY if the server uses an internal self-signed certificate.
EXCHANGE_VERIFY_SSL=true

# Calendar write (create/update/delete): false = read-only (default, recommended).
# Set true ONLY if you want to enable the commands that modify the calendar.
EXCHANGE_ENABLE_WRITE=false

# Allow non-HTTPS endpoints: keep false. true would expose NTLM credentials in clear text.
EXCHANGE_ALLOW_INSECURE=false
